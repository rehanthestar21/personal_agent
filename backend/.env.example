# Required
OPENAI_API_KEY=sk-your-key-here
JWT_SECRET=change-this-to-a-random-secret

# Optional
OPENAI_MODEL=gpt-5-mini
VERTEX_USER_NAME=Rehan
VERTEX_USER_LOCATION=London, UK
LOG_LEVEL=INFO

# MCP: Weather (https://openweathermap.org/api - free tier)
OPENWEATHERMAP_API_KEY=

# MCP: Web Search (https://tavily.com - free tier 1000/mo)
TAVILY_API_KEY=

# MCP: Spotify (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_REFRESH_TOKEN=

# MCP: WhatsApp (set to true, then run: cd mcp_servers/whatsapp && npm install && node bridge.js)
WHATSAPP_ENABLED=false
WHATSAPP_BRIDGE_URL=http://localhost:9777
# URL the bridge POSTs to for real-time incoming messages (delegated side agent)
VERTEX_BACKEND_URL=http://localhost:9000

# MCP: Google Calendar + Gmail (set to true after running: python mcp_servers/google_auth.py)
GOOGLE_ENABLED=false

# MCP: Google Maps (https://console.cloud.google.com > Enable Directions + Places + Geocoding APIs)
GOOGLE_MAPS_API_KEY=

# TTS: Indian English/Hindi voices (set false to use OpenAI TTS = Western voice)
# For Indian voice on a deployed server you MUST:
#   1. Enable Cloud Text-to-Speech API in Google Cloud
#   2. Create a service account and download its JSON key
#   3. On the server: export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
#   4. Ensure the JSON file is present on the server (e.g. in the same image/container)
# If GOOGLE_APPLICATION_CREDENTIALS is unset or file missing, backend falls back to OpenAI TTS (Western voice).
TTS_USE_GOOGLE=true



# MCP: GitHub (https://github.com/settings/tokens > Generate new token with repo scope)
GITHUB_TOKEN=
# Default GitHub username for "my repos" / shortcuts in the system prompt (optional)
GITHUB_USERNAME=

# FCM: push notifications to Android (alarm when someone escalates)
# Firebase Console > Project Settings > Service accounts > Generate new private key → save JSON
# Then set one of:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# FIREBASE_CREDENTIALS_PATH=/path/to/service-account.json

